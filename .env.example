# 로컬 실행 시 이 파일을 복사해 .env로 만들고 값을 채운 뒤,
# IDE Run Configuration 또는 셸 환경변수로 주입하세요. (Spring Boot는 .env를 자동 로드하지 않음)

DB_HOST=localhost
DB_PORT=3306
DB_NAME=finance_db
DB_USERNAME=root
DB_PASSWORD=

# Week 2 이후 사용
JWT_SECRET=
OPENAI_API_KEY=
EXIM_API_KEY=
ALPHA_VANTAGE_API_KEY=

# 시그널 이메일 알림 (Gmail 앱 비밀번호 사용)
MAIL_USERNAME=
MAIL_PASSWORD=
SIGNAL_MAIL_ENABLED=false
SIGNAL_CRON=0 30 9 * * MON-FRI
# ASG 등 다중 인스턴스 배포 시 false로 끄고 EventBridge+Lambda가 /api/internal/signals/generate를 호출하도록 한다.
SIGNAL_SCHEDULER_ENABLED=true

# Lambda 등 서버 간 호출이 /api/internal/** 에 접근할 때 쓰는 공유 토큰
SERVICE_TOKEN=
